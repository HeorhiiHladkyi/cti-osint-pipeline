# API keys are OPTIONAL. The pipeline runs without them using keyless sources
# (crt.sh, DNS, WHOIS, RDAP/ASN, URLScan public search). Keyed sources are skipped
# with a WARNING when their key is absent. Never commit your real .env.

VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
OTX_API_KEY=
# URLScan search works without a key; a key raises rate limits:
URLSCAN_API_KEY=

# Network timeout (seconds) per request
HTTP_TIMEOUT=15
